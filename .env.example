# CABP API Configuration
# The CABS backend should be running at this URL
CABP_BASE_URL=http://localhost:8000/api/v1
CABP_API_KEY=your_api_key_here

# Client Configuration
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=cabp_client.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Environment
ENVIRONMENT=development

# Feature Flags
ENABLE_DEBUG=false